          MODULE=webkit2gtk-4.1
         VERSION=2.52.4
          SOURCE=webkitgtk-$VERSION.tar.xz
      SOURCE_URL=https://www.webkitgtk.org/releases
      SOURCE_VFY=sha256:cf4076a1ca2a64788edca8c452d8ebb68d5e2965e588fe46a388a016513edce4
SOURCE_DIRECTORY=$BUILD_DIRECTORY/webkitgtk-$VERSION
        WEB_SITE=https://webkitgtk.org/
         ENTERED=20240911
         UPDATED=20260708
        REPLACES=webkit2gtk3
           SHORT="A Gtk4 web rendering engine"

cat << EOF
WebKitGTK+ is a web content engine, derived from KHTML and KJS from KDE, and
used primarily in Apple's Safari browser. It is made to be embedded in other
applications, such as mail readers, or web browsers. It is able to display
content such as HTML, SVG, XML, and others.
It also supports DOM, XMLHttpRequest, XSLT, CSS, Javascript/ECMAscript and
more.
EOF
